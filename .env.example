# Copiar a .env — no subir secretos al repositorio

DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# Railway MySQL (inyectadas en el servicio si referencias el plugin; el código también las lee):
# MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE

PORT=4000

# --- Envío Email 1 (SMTP; debe ser alcanzable desde Internet — p. ej. Railway) ---
# "Connection timeout" en error_envio = TCP no llega al servidor (host/puerto, firewall del hosting, IP bloqueada).
# Railway Free/Hobby: NO uses SMTP (bloqueado). Usa Resend u otro proveedor con API HTTPS:
RESEND_API_KEY=
# Opcional. Si está vacío, se usa el remitente de prueba de Resend (como el snippet del dashboard):
#   ABC Logistica <onboarding@resend.dev>
# NO dejes SMTP_USER/Gmail como From vía buildFromHeader — Resend lo rechaza sin dominio verificado.
# Con dominio verificado en Resend:
# RESEND_FROM=ABC Logística <design@abclogistica.mx>
# Prueba: npm run test:resend (tras deploy). Opcional: RESEND_TEST_TO=correo@destino.com
#
# Diagnóstico SMTP (solo si tu plan Railway permite SMTP, p. ej. Pro): npm run test:smtp
# Opciones que suelen funcionar desde la nube: Resend, Brevo, SendGrid, Mailgun, smtp.gmail.com (app password),
#   smtp.office365.com (Microsoft 365). Evita smtp de hosting compartido si solo permite tu IP de oficina.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_cuenta@gmail.com
SMTP_PASS=
# Contraseña de aplicación de Google si tienes 2FA
# Opcional: tiempo máx. de conexión en ms (default 30000)
# SMTP_CONNECTION_TIMEOUT_MS=45000
MAIL_FROM=
# Si vacío, se usa SMTP_USER
MAIL_BROADCAST_TO=usuarios@abclogistica.mx
# Lista “enviar a todos” → un solo destinatario (alias que redirige a clientes)
MAIL_SUBJECT_PREFIX=ABC Logística — Comunicado
# Si el logo existe en storage/plantillas, se adjunta como CID (no depende de esta URL).
# Si no hay archivo, se usa esta URL pública para el <img> del logo.
MAIL_ASSET_BASE_URL=http://localhost:4000
