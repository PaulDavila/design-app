# Copiar a .env.local y reiniciar `npm run dev`
# Valores por defecto si NO usas query en la URL (Email 1):
VITE_USER_ID=2
# user | admin | administrativo
VITE_USER_ROLE=user
#
# Tres roles en paralelo (mismo npm run dev), ejemplo:
#   http://localhost:5173/?e1_uid=1&e1_role=admin
#   http://localhost:5173/?e1_uid=2&e1_role=user
#   http://localhost:5173/?e1_uid=3&e1_role=administrativo
# Los ids deben existir en MySQL (users.id) y coincidir con X-User-Id del API vía Vite proxy.
# e1_uid y e1_role pisan VITE_* solo en Email 1 (panel + editor).
